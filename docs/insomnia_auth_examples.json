{
  "_type": "export",
  "__export_format": 4,
  "__export_date": "2025-11-30T00:00:00.000Z",
  "__export_source": "botla-co:insomnia-examples",
  "resources": [
    {
      "_id": "wrk_auth_examples",
      "_type": "workspace",
      "name": "Auth API Examples",
      "description": "Register/Login/Protected endpoints for botla-co"
    },
    {
      "_id": "env_auth_base",
      "_type": "environment",
      "parentId": "wrk_auth_examples",
      "name": "Base",
      "data": {
        "BASE_URL": "http://localhost:8080"
      }
    },
    {
      "_id": "req_register",
      "_type": "request",
      "parentId": "wrk_auth_examples",
      "name": "POST /api/v1/auth/register",
      "method": "POST",
      "url": "{{ BASE_URL }}/api/v1/auth/register",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\"email\":\"user@example.com\",\"password\":\"pass123\",\"full_name\":\"Ad Soyad\"}"
      }
    },
    {
      "_id": "req_login",
      "_type": "request",
      "parentId": "wrk_auth_examples",
      "name": "POST /api/v1/auth/login",
      "method": "POST",
      "url": "{{ BASE_URL }}/api/v1/auth/login",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\"email\":\"user@example.com\",\"password\":\"pass123\"}"
      }
    },
    {
      "_id": "req_protected",
      "_type": "request",
      "parentId": "wrk_auth_examples",
      "name": "GET /api/v1/protected",
      "method": "GET",
      "url": "{{ BASE_URL }}/api/v1/protected",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {% response 'body', 'req_login', '$.token' %}"
        }
      ]
    }
  ]
}
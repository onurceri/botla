{
  "name": "widget",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build && open dist/stats.html",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",

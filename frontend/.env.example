# Frontend environment variables
VITE_API_BASE_URL=http://localhost:8080
# Widget URL for Playground iframe preview (local dev uses widget dev server)
VITE_WIDGET_URL=http://localhost:5174
# Widget script URL for embed code and landing page widget (dev: /src/widget.tsx, prod: /widget.js)
VITE_WIDGET_SCRIPT_URL=http://localhost:5174/src/widget.tsx
# Set to "1" to bypass auth in tests or E2E flows
VITE_E2E=0

# Landing page chatbot ID
VITE_LANDING_CHATBOT_ID=

# PostHog Analytics
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

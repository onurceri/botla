# Frontend environment variables
VITE_API_BASE_URL=http://localhost:8080
# Widget URL for Playground iframe preview (local dev uses widget dev server)
VITE_WIDGET_URL=http://localhost:5174
# Widget script URL for embed code generation (production widget CDN)
VITE_WIDGET_SCRIPT_URL=http://localhost:5174/widget.js
# Set to "1" to bypass auth in tests or E2E flows
VITE_E2E=0

# PostHog Analytics
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

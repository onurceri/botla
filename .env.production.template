# Production Environment Variables Template
# Copy this to Render's Environment Variables section

# ============================================
# DATABASE (Neon PostgreSQL)
# ============================================
# Option 1: Single DATABASE_URL (recommended)
DATABASE_URL=postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require

# Option 2: Separate variables (if needed)
# DB_HOST=[host].neon.tech
# DB_PORT=5432
# DB_NAME=neondb
# DB_USER=[user]
# DB_PASSWORD=[password]
# DB_SCHEMA=public

# ============================================
# CACHE (Upstash Redis)
# ============================================
# IMPORTANT: Use Redis URL, NOT REST API URL
REDIS_URL=redis://default:[password]@[host].upstash.io:[port]

# ============================================
# VECTOR DATABASE (Qdrant Cloud)
# ============================================
QDRANT_URL=https://[cluster-id].eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=[your-qdrant-api-key]

# ============================================
# AI / LLM (OpenAI / OpenRouter)
# ============================================
# Required for embeddings
OPENAI_API_KEY=sk-...

# Optional: OpenRouter for cheaper LLM calls
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: Custom API endpoints
# OPENAI_API_BASE=https://api.openai.com
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# ============================================
# SECURITY
# ============================================
# Generate a strong secret (min 32 chars)
# Example: openssl rand -base64 32
JWT_SECRET=[your-super-secret-jwt-key-minimum-32-characters-long]

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8080
ENVIRONMENT=production

# CORS: Add your frontend domains (comma-separated)
CORS_ALLOWED_ORIGINS=https://botla.app,https://www.botla.app

# ============================================
# OBJECT STORAGE (Cloudflare R2)
# ============================================
R2_ACCOUNT_ID=[your-cloudflare-account-id]
R2_ACCESS_KEY_ID=[your-r2-access-key-id]
R2_SECRET_ACCESS_KEY=[your-r2-secret-access-key]
R2_BUCKET_NAME=botla-uploads

# ============================================
# PAYMENT GATEWAY (Iyzico)
# ============================================
# For production, use live credentials
# For testing, use sandbox credentials
IYZICO_API_KEY=[your-iyzico-api-key]
IYZICO_SECRET_KEY=[your-iyzico-secret-key]

# ============================================
# OPTIONAL CONFIGURATIONS
# ============================================
# RAG Configuration
# RAG_TOPK=5
# RAG_MAX_CONTEXT_TOKENS=2000

# Chat Configuration
# CHAT_TIMEOUT_MS=60000

# OpenAI Timeout
# OPENAI_TIMEOUT_MS=30000

# OpenRouter Timeout
# OPENROUTER_TIMEOUT_MS=30000

# Default Model
# DEFAULT_CHATBOT_MODEL=gpt-4o-mini
